# ──────────────────────────────────────────────────────────────
# Verificador SAG — variables de entorno
# Copia este archivo como `.env.local` y completa los valores.
# `.env.local` está en .gitignore: NUNCA se sube al repositorio.
# ──────────────────────────────────────────────────────────────

# API key de Google Gemini.
# Consíguela gratis en https://aistudio.google.com (formato típico: AIzaSy...).
# El adaptador también acepta un access token OAuth (se envía como Bearer).
GEMINI_API_KEY=

# Rotación de keys (opcional). Varias keys separadas por coma: ante un 429
# (cuota agotada) el servidor reintenta con la siguiente. Si se define, tiene
# prioridad sobre GEMINI_API_KEY.
# GEMINI_API_KEYS=AIzaKey1,AIzaKey2,AIzaKey3

# Modelo a usar (opcional). Por defecto: gemini-2.5-flash
# Otras opciones con visión: gemini-2.0-flash, gemini-flash-latest
GEMINI_MODEL=gemini-2.5-flash

# Modo de autenticación (opcional). Por defecto la credencial se envía como
# API key (?key=...). Solo poner "bearer" si usas un access token OAuth.
# GEMINI_AUTH=bearer

# ── Pre-procesamiento de imágenes (opcional) ──
# Antes de mandar una imagen a Gemini se reduce su resolución para gastar
# menos tokens (Gemini cobra por dimensiones, no por peso). Los PDF no se tocan.

# Lado mayor máximo en píxeles. Por defecto: 1536 (= 2×768, borde limpio de tile).
# Subir si el texto de tus documentos queda ilegible; bajar para ahorrar más.
# EXTRACT_MAX_IMAGE_PX=1536

# Calidad JPEG de salida (1-100). Afecta peso/subida, NO el conteo de tokens.
# EXTRACT_JPEG_QUALITY=82
